<wdkModel>

  <recordClassSet name="communityDatasetRecordClasses">

    <!-- ################################################################### -->
    <!-- #####################  Community Dataset Record ################### -->
    <!-- ################################################################### -->

    <recordClass name="communityDataset" urlName="community-dataset" displayName="Community Study">
      <propertyList name="batch">
        <value>dataset-presenter</value>
      </propertyList>

      <primaryKey aliasPluginClassName="org.gusdb.wdk.model.record.GenericRecordPrimaryKeyAliasPlugin">
        <columnRef>dataset_id</columnRef>
      </primaryKey>

      <idAttribute name="primary_key" displayName="Dataset Name">
        <propertyList name="boost">
          <value>100</value>
        </propertyList>
        <text>
          <![CDATA[ $$display_name$$ ]]>
        </text>
      </idAttribute>

      <reporter name="solrjson"
                displayName="solr json: choose from columns and/or tables"
                scopes=""
                implementation="org.eupathdb.sitesearch.data.model.report.SolrLoaderReporter"/>

      <attributeQueryRef ref="CommunityDatasetAttributes.All">
        <columnAttribute name="project" displayName="dontcare" internal="true"/>  <!-- special field for project filtering -->
        <columnAttribute name="hyperlinkName" displayName="dontcare" internal="true"/> <!-- used for display in ss results -->
        <columnAttribute name="display_name" internal="true"/>
        <columnAttribute name="description" displayName="Description">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
          <propertyList name="boost"> 
            <value>20</value>
          </propertyList>
	</columnAttribute>
        <columnAttribute name="summary" displayName="Summary">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
          <propertyList name="isSummary">
            <value>true</value>
          </propertyList>
          <propertyList name="boost">  
            <value>20</value>
          </propertyList>
	</columnAttribute>		
      </attributeQueryRef>

      <attributeQueryRef ref="CommunityDatasetAttributes.OwnerInfo">
        <columnAttribute name="owner_name">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
        <columnAttribute name="owner_organization">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </attributeQueryRef>

      <table name="Contacts"
             displayName="Principal Investigator and Collaborators"
             queryRef="CommunityDatasetTables.contacts">
        <propertyList name="boost"> 
          <value>20</value>
        </propertyList>   	      
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="contact_name" displayName="Investigator">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
        <columnAttribute name="affiliation" displayName="Affiliation">  
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Publications"
             displayName="Associated publications"
             queryRef="CommunityDatasetTables.publications">
        <propertyList name="boost">
          <value>20</value>
        </propertyList>
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="publication_id" displayName="Publication ID"/>
        <columnAttribute name="citation" displayName="Citation">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Hyperlinks"
             displayName="Related links"
             queryRef="CommunityDatasetTables.hyperlinks">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="text" displayName="Link text">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
        <columnAttribute name="description" displayName="Description">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Organisms"
             displayName="Organisms"
             queryRef="CommunityDatasetTables.organisms">
        <propertyList name="includeProjects">
          <value>MicrosporidiaDB</value>
          <value>TrichDB</value>
          <value>FungiDB</value>
          <value>PlasmoDB</value>
          <value>PiroplasmaDB</value>
          <value>TriTrypDB</value>
          <value>HostDB</value>
          <value>ToxoDB</value>
          <value>CryptoDB</value>
          <value>VectorBase</value>
          <value>GiardiaDB</value>
          <value>AmoebaDB</value>
          <value>UniDB</value>
        </propertyList>
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="organism_name">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Countries"
             displayName="Countries"
             queryRef="CommunityDatasetTables.countries">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="country" displayName="Country">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Species"
             displayName="Species"
             queryRef="CommunityDatasetTables.species">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="species" displayName="Species">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="AssociatedFactors"
             displayName="Associated factors"
             queryRef="CommunityDatasetTables.associatedFactors">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="factor" displayName="Factor">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="DOIs"
             displayName="DOIs"
             queryRef="CommunityDatasetTables.dois">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="doi" displayName="DOI"/>
        <columnAttribute name="description" displayName="Description">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="BioprojectIds"
             displayName="Bioproject IDs"
             queryRef="CommunityDatasetTables.bioprojectIds">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="bioproject_id" displayName="Bioproject ID"/>
        <columnAttribute name="description" displayName="Description">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="FundingAwards"
             displayName="Funding awards"
             queryRef="CommunityDatasetTables.fundingAwards">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="agency" displayName="Agency">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
        <columnAttribute name="award_number" displayName="Award number">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Outcomes"
             displayName="Outcomes"
             queryRef="CommunityDatasetTables.outcomes">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="outcome" displayName="Outcome">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="Characteristics"
             displayName="Study characteristics"
             queryRef="CommunityDatasetTables.characteristics">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="study_design" displayName="Study design">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
        <columnAttribute name="study_type" displayName="Study type">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="SampleTypes"
             displayName="Sample types"
             queryRef="CommunityDatasetTables.sampleTypes">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="sample_type" displayName="Sample type">
          <propertyList name="autocomplete">
            <value>true</value>
	  </propertyList>
	</columnAttribute>
      </table>

      <table name="LinkedDatasets"
             displayName="Linked datasets"
             queryRef="CommunityDatasetTables.LinkedDatasets">
        <columnAttribute name="dataset_id"/>
        <columnAttribute name="linked_dataset_id" displayName="Linked dataset ID"/>
      </table>


    </recordClass>
    

  </recordClassSet>

</wdkModel>
